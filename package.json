{
    "name": "node-red-render",
    "description": "A Node-RED Project",
    "version": "0.0.1",
    "scripts": {
        "start": "node --max-old-space-size=4096 node_modules/node-red/red.js --settings ./settings.js --userDir ."
    },
    "dependencies": {
        "node-red": "4.1.8"
    },
    "node-red": {
        "settings": {
            "flowFile": "flows.json",
            "credentialsFile": "flows_cred.json"
        }
    }
}