    {
        "id": "clean1",
        "type": "function",
        "z": "e7147f212e63eb38",
        "name": "Step 1: Data Cleaning",
        "func": "// Handle missing values\nif (!msg.payload.temp) msg.payload.temp = 20;\nif (!msg.payload.rain_1h) msg.payload.rain_1h = 0;\n//if (!msg.payload.traffic_volume) return null;\n\n// 临时将这行注释掉（在前面加 //）\n// if (!msg.payload.traffic_volume) return null; \n// 暂时注释掉拦截逻辑，改用日志输出\nif (!msg.payload.traffic_volume && msg.payload.traffic_volume !== 0) {\n    node.warn(\"数据被拦截：未找到 traffic_volume。当前 payload 内容: \" + JSON.stringify(msg.payload));\n        return null; // 如果确定没数据，依然需要返回 null 防止下游报错\n        }\n\n        // 正常逻辑\n        if (!msg.payload.temp) msg.payload.temp = 20;\n        if (!msg.payload.rain_1h) msg.payload.rain_1h = 0;\n        msg.payload.traffic_volume = Math.max(0, msg.payload.traffic_volume);\n\n        return msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 160,
        "y": 360,
        "wires": [
            [
                "7e16dbcd969ef943",
                "feature1"
            ]
        ]
    },
    {
        "id": "feature1",
        "type": "function",
        "z": "e7147f212e63eb38",
        "name": "Step 2: Feature Engineering",
        "func": "// Convert date\nlet date = new Date(msg.payload.date_time);\n\n// Extract hour\nmsg.payload.hour = date.getHours();\n\n// Create peak hour feature\n// Used 1 and 0 to replace True & False\nmsg.payload.is_peak = (msg.payload.hour >= 7 && msg.payload.hour <= 9) || \n                      (msg.payload.hour >= 16 && msg.payload.hour <= 18) ? 1 : 0;\n\n// Day of week\n// 0 - Sunday, 6 - Saturday\nmsg.payload.day_of_week = date.getDay();\n\n// Traffic Level\n// Low (0), Medium (1), High (2)\nlet volume = msg.payload.traffic_volume;\nif (volume < 1500) {\n    msg.payload.traffic_level = 0; // Low\n} else if (volume < 4500) {\n    msg.payload.traffic_level = 1; // Medium\n} else {\n    msg.payload.traffic_level = 2; // High\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 440,
        "wires": [
            [
                "debug1",
                "save1",
                "75d717f69cc21bee"
            ]
        ]
    },
    {
        "id": "save1",
        "type": "function",
        "z": "e7147f212e63eb38",
        "name": "Format for CSV",
        "func": "let p = msg.payload;\nmsg.payload = `${p.date_time},${p.traffic_volume},${p.temp},${p.rain_1h},${p.hour},${p.is_peak},${p.day_of_week},${p.traffic_level}\\n`;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
