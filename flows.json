        "type": "function",
        "z": "e7147f212e63eb38",
        "name": "Feature Engineering",
        "func": "let date = new Date(msg.payload.date_time);\n\n// Extract hour\nmsg.payload.hour = date.getHours();\n\n// Peak hour\nmsg.payload.is_peak = (msg.payload.hour >= 7 && msg.payload.hour <= 9) ||\n    (msg.payload.hour >= 16 && msg.payload.hour <= 18);\n\n// Normalize\nmsg.payload.traffic_scaled = msg.payload.traffic_volume / 10000;\n\nreturn msg;",
