    {
        "id": "75ec954d474e76da",
        "type": "function",
        "z": "e7147f212e63eb38",
        "name": "Data Cleaning",
        "func": "// Handle missing values\nif (!msg.payload.temp) msg.payload.temp = 20;\nif (!msg.payload.rain_1h) msg.payload.rain_1h = 0;\n\n// Remove invalid data\nif (!msg.payload.traffic_volume) return null;\nmsg.payload.traffic_volume = Math.max(0, msg.payload.traffic_volume);\n\nreturn msg;\n",
        "outputs": 1,
