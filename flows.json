    {
        "id": "clean1",
        "type": "function",
        "z": "e7147f212e63eb38",
        "name": "Step 1: Data Cleaning",
        "func": "// --- 1. Data Cleaning (Handling missing values) ---\n// Set default values if temp or rain_1h are missing\nif (!msg.payload.temp) msg.payload.temp = 20;\nif (!msg.payload.rain_1h) msg.payload.rain_1h = 0;\n\n// Validate that traffic_volume exists; stop flow if invalid\nif (!msg.payload.traffic_volume && msg.payload.traffic_volume !== 0) {\n    node.warn(\"Data blocked: traffic_volume missing. Payload: \" + JSON.stringify(msg.payload));\n    return null;\n}\n\n// Ensure traffic_volume is a non-negative number\nmsg.payload.traffic_volume = Math.max(0, msg.payload.traffic_volume);\n\n\n// --- 2. Feature Engineering (Extracting time and normalizing data) ---\n// Parse the date_time string to extract specific features\nlet date = new Date(msg.payload.date_time);\n\n// Extract hour from date\nmsg.payload.hour = date.getHours();\n\n// Define peak hours (7-9 AM, 4-6 PM)\nmsg.payload.is_peak = (msg.payload.hour >= 7 && msg.payload.hour <= 9) ||\n    (msg.payload.hour >= 16 && msg.payload.hour <= 18) ? 1 : 0;\n\n// Scale traffic volume for model input consistency\nmsg.payload.traffic_scaled = msg.payload.traffic_volume / 10000;\n\n\n// --- 3. Label Generation (Categorizing traffic levels) ---\n// Assign traffic level: 0 (Low), 1 (Medium), 2 (High)\nif (msg.payload.traffic_volume < 1500) {\n    msg.payload.traffic_level = 0;\n} else if (msg.payload.traffic_volume < 4000) {\n    msg.payload.traffic_level = 1;\n} else {\n    msg.payload.traffic_level = 2;\n}\n\n// Pass the processed message to the next node\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 160,
        "y": 360,
        "wires": [
            [
                "7e16dbcd969ef943",
                "feature1"
            ]
        ]
    },
    {
        "id": "feature1",
        "type": "function",
        "z": "e7147f212e63eb38",
        "name": "Step 2: Feature Engineering",
        "func": "// Convert date\nlet date = new Date(msg.payload.date_time);\n\n// Extract hour\nmsg.payload.hour = date.getHours();\n\n// Create peak hour feature\n// Used 1 and 0 to replace True & False\nmsg.payload.is_peak = (msg.payload.hour >= 7 && msg.payload.hour <= 9) || \n                      (msg.payload.hour >= 16 && msg.payload.hour <= 18) ? 1 : 0;\n\n// Day of week\n// 0 - Sunday, 6 - Saturday\nmsg.payload.day_of_week = date.getDay();\n\n// Traffic Level\n// Low (0), Medium (1), High (2)\nlet volume = msg.payload.traffic_volume;\nif (volume < 1500) {\n    msg.payload.traffic_level = 0; // Low\n} else if (volume < 4500) {\n    msg.payload.traffic_level = 1; // Medium\n} else {\n    msg.payload.traffic_level = 2; // High\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 440,
