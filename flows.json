        "func": "var level = msg.payload.traffic_level;\nif (level === 2) {\n    msg.payload = \"⚠️ HIGH TRAFFIC! Deploy extra transport now.\";\n} else if (level === 1) {\n    msg.payload = \"ℹ️ Medium traffic. Monitor the situation.\";\n} else {\n    msg.payload = \"✅ Traffic is normal. No action needed.\";\n}\nmsg.trafficLevel = level; // use this instead of msg.topic\nreturn msg;",
