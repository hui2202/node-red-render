    {
        "id": "ef33aba968250a52",
        "type": "ui_template",
        "z": "e7147f212e63eb38",
        "group": "1c15399f1cf0af22",
        "name": "",
        "order": 3,
        "width": "12",
        "height": "27",
        "format": "<style>\n  svg {\n    overflow: hidden;\n    display: block;\n  }\n\n  .dash {\n    padding: 24px;\n    font-family: 'Segoe UI', sans-serif;\n    background: #f0f4f8;\n    margin: -16px;\n    overflow: hidden;\n    box-sizing: border-box;\n    width: 100%;\n  }\n\n  .header {\n    background: #1e3a5f;\n    border-radius: 12px;\n    padding: 20px;\n    text-align: center;\n    margin-bottom: 18px;\n  }\n\n  .notif {\n    border-radius: 10px;\n    padding: 14px 20px;\n    margin-bottom: 18px;\n    font-size: 14px;\n    font-weight: 600;\n    text-align: center;\n  }\n\n  .card {\n    background: #ffffff !important;\n    border: 1px solid #d1dce8;\n    border-radius: 12px;\n    padding: 20px;\n    margin-bottom: 16px;\n    overflow: hidden;\n    box-sizing: border-box;\n  }\n\n  .card-label {\n    color: #7a96b0;\n    font-size: 11px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    margin-bottom: 12px;\n    text-align: center;\n  }\n\n  .status-badge {\n    display: block;\n    padding: 14px;\n    border-radius: 30px;\n    font-size: 20px;\n    font-weight: 700;\n    letter-spacing: 4px;\n    text-align: center;\n  }\n\n  .recom {\n    background: #ffffff !important;\n    border: 1px solid #d1dce8;\n    border-radius: 12px;\n    padding: 16px 20px;\n    text-align: center;\n    font-size: 14px;\n    font-weight: 500;\n    line-height: 1.6;\n    box-sizing: border-box;\n  }\n\n  .chart-wrap {\n    display: flex;\n    gap: 8px;\n    align-items: stretch;\n  }\n\n  .chart-yaxis {\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    padding-bottom: 2px;\n    padding-right: 6px;\n    min-width: 28px;\n    text-align: right;\n  }\n\n  .chart-bars {\n    flex: 1;\n    display: flex;\n    align-items: flex-end;\n    gap: 5px;\n    height: 160px;\n    border-bottom: 2px solid #d1dce8;\n    border-left: 2px solid #d1dce8;\n    padding: 8px 4px 0 4px;\n  }\n\n  .chart-bar {\n    flex: 1;\n    border-radius: 4px 4px 0 0;\n    min-width: 8px;\n  }\n</style>\n\n<div class=\"dash\">\n\n  <div class=\"header\">\n    <div style=\"margin:0; color:#e8f4fd; font-size:20px; letter-spacing:3px; font-weight:700;\">🚌 SMART TRANSPORT\n      MONITOR</div>\n    <div style=\"margin:6px 0 0; color:#90b8d4; font-size:11px; letter-spacing:2px;\">REAL-TIME ML TRAFFIC PREDICTION —\n      NODE-RED</div>\n  </div>\n\n  <!-- LOW -->\n  <div ng-if=\"msg.payload.traffic_level === 0\">\n    <div class=\"notif\" style=\"background:#e8f8f0; border:1px solid #27ae60; color:#1e8449;\">\n      ✅ Traffic is normal. No action needed.\n    </div>\n    <div class=\"card\" style=\"text-align:center;\">\n      <div class=\"card-label\" style=\"margin-bottom:20px;\">Traffic Level</div>\n      <svg width=\"100%\" height=\"175\" viewBox=\"0 0 260 160\" style=\"overflow:visible;\">\n        <path d=\"M20,110 A100,100 0 0,1 86,21\" fill=\"none\" stroke=\"#27ae60\" stroke-width=\"16\" stroke-linecap=\"round\" />\n        <path d=\"M90,20 A100,100 0 0,1 170,20\" fill=\"none\" stroke=\"#e67e22\" stroke-width=\"16\" stroke-linecap=\"round\"\n          opacity=\"0.3\" />\n        <path d=\"M174,21 A100,100 0 0,1 240,110\" fill=\"none\" stroke=\"#c0392b\" stroke-width=\"16\" stroke-linecap=\"round\"\n          opacity=\"0.3\" />\n        <line x1=\"130\" y1=\"110\" x2=\"32\" y2=\"110\" stroke=\"#1e3a5f\" stroke-width=\"3.5\" stroke-linecap=\"round\" />\n        <circle cx=\"130\" cy=\"110\" r=\"9\" fill=\"#1e3a5f\" />\n        <circle cx=\"130\" cy=\"110\" r=\"4\" fill=\"white\" />\n        <text x=\"130\" y=\"145\" text-anchor=\"middle\" fill=\"#27ae60\" font-size=\"28\" font-weight=\"bold\">0</text>\n        <text x=\"8\" y=\"128\" fill=\"#27ae60\" font-size=\"11\" font-weight=\"600\">LOW</text>\n        <text x=\"110\" y=\"1\" fill=\"#7a96b0\" font-size=\"11\">MED</text>\n        <text x=\"218\" y=\"128\" fill=\"#7a96b0\" font-size=\"11\">HIGH</text>\n      </svg>\n      <div style=\"font-size:11px;color:#7a96b0;margin-top:4px;\">0 = Low &nbsp;|&nbsp; 1 = Medium &nbsp;|&nbsp; 2 = High\n      </div>\n    </div>\n    <div class=\"card\">\n      <div class=\"card-label\">Traffic History (Last 20 Readings)</div>\n      <div class=\"chart-wrap\">\n        <div class=\"chart-yaxis\">\n          <span style=\"font-size:10px;color:#c0392b;\">High</span>\n          <span style=\"font-size:10px;color:#e67e22;\">Med</span>\n          <span style=\"font-size:10px;color:#27ae60;\">Low</span>\n        </div>\n        <div class=\"chart-bars\">\n          <div class=\"chart-bar\" ng-repeat=\"h in hist track by $index\" ng-style=\"{\n              'height': (h === 0 ? '20%' : h === 1 ? '55%' : '95%'),\n              'background': (h === 0 ? '#27ae60' : h === 1 ? '#e67e22' : '#c0392b'),\n              'opacity': ($index === hist.length-1) ? '1' : '0.6'\n            }\">\n          </div>\n        </div>\n      </div>\n      <div style=\"display:flex; justify-content:space-between; margin-top:10px; align-items:center;\">\n        <span style=\"font-size:10px;color:#7a96b0;\">← Older</span>\n        <div style=\"display:flex;gap:14px;\">\n          <span style=\"font-size:10px;color:#27ae60;\">■ Low</span>\n          <span style=\"font-size:10px;color:#e67e22;\">■ Med</span>\n          <span style=\"font-size:10px;color:#c0392b;\">■ High</span>\n        </div>\n        <span style=\"font-size:10px;color:#7a96b0;\">Latest →</span>\n      </div>\n    </div>\n    <div class=\"card\">\n      <div class=\"card-label\">Status</div>\n      <div class=\"status-badge\" style=\"background:#e8f8f0;color:#1e8449;border:2px solid #27ae60;\">LOW</div>\n    </div>\n    <div class=\"recom\" style=\"color:#1e8449;\">✅ Traffic is normal. No action needed.</div>\n  </div>\n\n  <!-- MEDIUM -->\n  <div ng-if=\"msg.payload.traffic_level === 1\">\n    <div class=\"notif\" style=\"background:#fef5e7; border:1px solid #e67e22; color:#b7600d;\">\n      ℹ️ Medium traffic. Monitor the situation.\n    </div>\n    <div class=\"card\" style=\"text-align:center;\">\n      <div class=\"card-label\" style=\"margin-bottom:20px;\">Traffic Level</div>\n      <svg width=\"100%\" height=\"175\" viewBox=\"0 0 260 160\" style=\"overflow:visible;\">\n        <path d=\"M20,110 A100,100 0 0,1 86,21\" fill=\"none\" stroke=\"#27ae60\" stroke-width=\"16\" stroke-linecap=\"round\"\n          opacity=\"0.3\" />\n        <path d=\"M90,20 A100,100 0 0,1 170,20\" fill=\"none\" stroke=\"#e67e22\" stroke-width=\"16\" stroke-linecap=\"round\" />\n        <path d=\"M174,21 A100,100 0 0,1 240,110\" fill=\"none\" stroke=\"#c0392b\" stroke-width=\"16\" stroke-linecap=\"round\"\n          opacity=\"0.3\" />\n        <line x1=\"130\" y1=\"110\" x2=\"130\" y2=\"18\" stroke=\"#1e3a5f\" stroke-width=\"3.5\" stroke-linecap=\"round\" />\n        <circle cx=\"130\" cy=\"110\" r=\"9\" fill=\"#1e3a5f\" />\n        <circle cx=\"130\" cy=\"110\" r=\"4\" fill=\"white\" />\n        <text x=\"130\" y=\"145\" text-anchor=\"middle\" fill=\"#e67e22\" font-size=\"28\" font-weight=\"bold\">1</text>\n        <text x=\"8\" y=\"128\" fill=\"#7a96b0\" font-size=\"11\">LOW</text>\n        <text x=\"110\" y=\"1\" fill=\"#e67e22\" font-size=\"11\" font-weight=\"600\">MED</text>\n        <text x=\"218\" y=\"128\" fill=\"#7a96b0\" font-size=\"11\">HIGH</text>\n      </svg>\n      <div style=\"font-size:11px;color:#7a96b0;margin-top:4px;\">0 = Low &nbsp;|&nbsp; 1 = Medium &nbsp;|&nbsp; 2 = High\n      </div>\n    </div>\n    <div class=\"card\">\n      <div class=\"card-label\">Traffic History (Last 20 Readings)</div>\n      <div class=\"chart-wrap\">\n        <div class=\"chart-yaxis\">\n          <span style=\"font-size:10px;color:#c0392b;\">High</span>\n          <span style=\"font-size:10px;color:#e67e22;\">Med</span>\n          <span style=\"font-size:10px;color:#27ae60;\">Low</span>\n        </div>\n        <div class=\"chart-bars\">\n          <div class=\"chart-bar\" ng-repeat=\"h in hist track by $index\" ng-style=\"{\n              'height': (h === 0 ? '20%' : h === 1 ? '55%' : '95%'),\n              'background': (h === 0 ? '#27ae60' : h === 1 ? '#e67e22' : '#c0392b'),\n              'opacity': ($index === hist.length-1) ? '1' : '0.6'\n            }\">\n          </div>\n        </div>\n      </div>\n      <div style=\"display:flex; justify-content:space-between; margin-top:10px; align-items:center;\">\n        <span style=\"font-size:10px;color:#7a96b0;\">← Older</span>\n        <div style=\"display:flex;gap:14px;\">\n          <span style=\"font-size:10px;color:#27ae60;\">■ Low</span>\n          <span style=\"font-size:10px;color:#e67e22;\">■ Med</span>\n          <span style=\"font-size:10px;color:#c0392b;\">■ High</span>\n        </div>\n        <span style=\"font-size:10px;color:#7a96b0;\">Latest →</span>\n      </div>\n    </div>\n    <div class=\"card\">\n      <div class=\"card-label\">Status</div>\n      <div class=\"status-badge\" style=\"background:#fef5e7;color:#b7600d;border:2px solid #e67e22;\">MEDIUM</div>\n    </div>\n    <div class=\"recom\" style=\"color:#b7600d;\">ℹ️ Medium traffic detected. Monitor the situation closely.</div>\n  </div>\n\n  <!-- HIGH -->\n  <div ng-if=\"msg.payload.traffic_level === 2\">\n    <div class=\"notif\" style=\"background:#fdecea; border:1px solid #c0392b; color:#922b21;\">\n      ⚠️ HIGH TRAFFIC ALERT! Deploy extra transport resources immediately.\n    </div>\n    <div class=\"card\" style=\"text-align:center;\">\n      <div class=\"card-label\" style=\"margin-bottom:20px;\">Traffic Level</div>\n      <svg width=\"100%\" height=\"175\" viewBox=\"0 0 260 160\" style=\"overflow:visible;\">\n        <path d=\"M20,110 A100,100 0 0,1 86,21\" fill=\"none\" stroke=\"#27ae60\" stroke-width=\"16\" stroke-linecap=\"round\"\n          opacity=\"0.3\" />\n        <path d=\"M90,20 A100,100 0 0,1 170,20\" fill=\"none\" stroke=\"#e67e22\" stroke-width=\"16\" stroke-linecap=\"round\"\n          opacity=\"0.3\" />\n        <path d=\"M174,21 A100,100 0 0,1 240,110\" fill=\"none\" stroke=\"#c0392b\" stroke-width=\"16\"\n          stroke-linecap=\"round\" />\n        <line x1=\"130\" y1=\"110\" x2=\"228\" y2=\"110\" stroke=\"#1e3a5f\" stroke-width=\"3.5\" stroke-linecap=\"round\" />\n        <circle cx=\"130\" cy=\"110\" r=\"9\" fill=\"#1e3a5f\" />\n        <circle cx=\"130\" cy=\"110\" r=\"4\" fill=\"white\" />\n        <text x=\"130\" y=\"145\" text-anchor=\"middle\" fill=\"#c0392b\" font-size=\"28\" font-weight=\"bold\">2</text>\n        <text x=\"8\" y=\"128\" fill=\"#7a96b0\" font-size=\"11\">LOW</text>\n        <text x=\"110\" y=\"1\" fill=\"#7a96b0\" font-size=\"11\">MED</text>\n        <text x=\"218\" y=\"128\" fill=\"#c0392b\" font-size=\"11\" font-weight=\"600\">HIGH</text>\n      </svg>\n      <div style=\"font-size:11px;color:#7a96b0;margin-top:4px;\">0 = Low &nbsp;|&nbsp; 1 = Medium &nbsp;|&nbsp; 2 = High\n      </div>\n    </div>\n    <div class=\"card\">\n      <div class=\"card-label\">Traffic History (Last 20 Readings)</div>\n      <div class=\"chart-wrap\">\n        <div class=\"chart-yaxis\">\n          <span style=\"font-size:10px;color:#c0392b;\">High</span>\n          <span style=\"font-size:10px;color:#e67e22;\">Med</span>\n          <span style=\"font-size:10px;color:#27ae60;\">Low</span>\n        </div>\n        <div class=\"chart-bars\">\n          <div class=\"chart-bar\" ng-repeat=\"h in hist track by $index\" ng-style=\"{\n              'height': (h === 0 ? '20%' : h === 1 ? '55%' : '95%'),\n              'background': (h === 0 ? '#27ae60' : h === 1 ? '#e67e22' : '#c0392b'),\n              'opacity': ($index === hist.length-1) ? '1' : '0.6'\n            }\">\n          </div>\n        </div>\n      </div>\n      <div style=\"display:flex; justify-content:space-between; margin-top:10px; align-items:center;\">\n        <span style=\"font-size:10px;color:#7a96b0;\">← Older</span>\n        <div style=\"display:flex;gap:14px;\">\n          <span style=\"font-size:10px;color:#27ae60;\">■ Low</span>\n          <span style=\"font-size:10px;color:#e67e22;\">■ Med</span>\n          <span style=\"font-size:10px;color:#c0392b;\">■ High</span>\n        </div>\n        <span style=\"font-size:10px;color:#7a96b0;\">Latest →</span>\n      </div>\n    </div>\n    <div class=\"card\">\n      <div class=\"card-label\">Status</div>\n      <div class=\"status-badge\" style=\"background:#fdecea;color:#922b21;border:2px solid #c0392b;\">HIGH</div>\n    </div>\n    <div class=\"recom\" style=\"color:#922b21;\">⚠️ HIGH TRAFFIC! Deploy extra transport resources immediately.</div>\n  </div>\n\n<script>\n  (function(scope) {\n\n  // History tracking\n  if (!scope.hist) {\n    scope.hist = [];\n  }\n\n  scope.$watch('msg', function(msg) {\n    if (msg && msg.payload && msg.payload.traffic_level !== undefined) {\n      scope.hist.push(msg.payload.traffic_level);\n      if (scope.hist.length > 20) {\n        scope.hist = scope.hist.slice(-20);\n      }\n    }\n  });\n\n  // Manual prediction - INSIDE the wrapper\n  if (!scope.manual) {\n    scope.manual = { temp: null, rain: null, hour: null, is_peak: \"0\", day: \"0\" };\n  }\n  scope.manualResult = null;\n\n  scope.predict = function() {\n    var temp = parseFloat(scope.manual.temp) + 273.15;\n    var rain = parseFloat(scope.manual.rain);\n    var hour = parseInt(scope.manual.hour);\n    var is_peak = parseInt(scope.manual.is_peak);\n    var day = parseInt(scope.manual.day);\n\n    fetch(\"/manual-predict\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        temp: temp,\n        rain_1h: rain,\n        hour: hour,\n        is_peak: is_peak,\n        day_of_week: day\n      })\n    })\n    .then(function(res) { return res.json(); })\n    .then(function(data) {\n      scope.$apply(function() {\n        scope.manualResult = parseInt(data.traffic_level);\n      });\n    })\n    .catch(function(err) {\n      console.error(\"Prediction error:\", err);\n    });\n  };\n  scope.resetManual = function() {\n  scope.manual = { temp: null, rain: null, hour: null, is_peak: \"0\", day: \"0\" };\n  scope.manualResult = null;\n  };\n\n})(scope);\n</script>\n<!-- MANUAL PREDICTION FORM -->\n<div class=\"card\" style=\"margin-top:16px;\">\n  <div class=\"card-label\">Manual Prediction</div>\n\n  <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:12px;\">\n    \n    <div>\n      <div style=\"font-size:10px;color:#7a96b0;margin-bottom:4px;\">Temperature (°C)</div>\n      <input type=\"number\" ng-model=\"manual.temp\" placeholder=\"e.g. 25\"\n        style=\"width:100%;padding:8px;border:1px solid #d1dce8;border-radius:8px;font-size:13px;box-sizing:border-box;\">\n    </div>\n\n    <div>\n      <div style=\"font-size:10px;color:#7a96b0;margin-bottom:4px;\">Rain last 1h (mm)</div>\n      <input type=\"number\" ng-model=\"manual.rain\" placeholder=\"e.g. 0 if no rain\"\n        style=\"width:100%;padding:8px;border:1px solid #d1dce8;border-radius:8px;font-size:13px;box-sizing:border-box;\">\n    </div>\n\n    <div>\n      <div style=\"font-size:10px;color:#7a96b0;margin-bottom:4px;\">Hour of Day (0 – 23)</div>\n      <input type=\"number\" ng-model=\"manual.hour\" placeholder=\"e.g. 17 for 5pm\" min=\"0\" max=\"23\" step=\"1\"\n        style=\"width:100%;padding:8px;border:1px solid #d1dce8;border-radius:8px;font-size:13px;box-sizing:border-box;\">\n    </div>\n\n    <div>\n      <div style=\"font-size:10px;color:#7a96b0;margin-bottom:4px;\">Peak Hour?</div>\n      <select ng-model=\"manual.is_peak\"\n        style=\"width:100%;padding:8px;border:1px solid #d1dce8;border-radius:8px;font-size:13px;box-sizing:border-box;\">\n        <option value=\"1\">Yes</option>\n        <option value=\"0\">No</option>\n      </select>\n    </div>\n\n    <div style=\"grid-column:span 2;\">\n      <div style=\"font-size:10px;color:#7a96b0;margin-bottom:4px;\">Day of Week</div>\n      <select ng-model=\"manual.day\"\n        style=\"width:100%;padding:8px;border:1px solid #d1dce8;border-radius:8px;font-size:13px;box-sizing:border-box;\">\n        <option value=\"0\">Monday</option>\n        <option value=\"1\">Tuesday</option>\n        <option value=\"2\">Wednesday</option>\n        <option value=\"3\">Thursday</option>\n        <option value=\"4\">Friday</option>\n        <option value=\"5\">Saturday</option>\n        <option value=\"6\">Sunday</option>\n      </select>\n    </div>\n  </div>\n\n  <!-- Predict Button -->\n  <button ng-click=\"predict()\"\n    style=\"width:100%;padding:12px;background:#1e3a5f;color:white;border:none;border-radius:8px;font-size:14px;font-weight:700;letter-spacing:2px;cursor:pointer;\">\n    PREDICT\n  </button>\n  <!-- Reset Button -->\n  <button ng-click=\"resetManual()\"\n    style=\"width:100%;padding:12px;background:#ffffff;color:#7a96b0;border:1px solid #d1dce8;border-radius:8px;font-size:14px;font-weight:700;letter-spacing:2px;cursor:pointer;margin-top:8px;\">\n    RESET\n  </button>\n\n  <!-- Result -->\n  <div ng-if=\"manualResult !== null\" style=\"margin-top:12px;text-align:center;\">\n    <div style=\"font-size:10px;color:#7a96b0;letter-spacing:2px;margin-bottom:6px;\">PREDICTION RESULT</div>\n    <div ng-if=\"manualResult === 0\" style=\"padding:12px;background:#e8f8f0;border:2px solid #27ae60;border-radius:8px;color:#1e8449;font-weight:700;font-size:16px;\">\n      ✅ LOW TRAFFIC\n    </div>\n    <div ng-if=\"manualResult === 1\" style=\"padding:12px;background:#fef5e7;border:2px solid #e67e22;border-radius:8px;color:#b7600d;font-weight:700;font-size:16px;\">\n      ℹ️ MEDIUM TRAFFIC\n    </div>\n    <div ng-if=\"manualResult === 2\" style=\"padding:12px;background:#fdecea;border:2px solid #c0392b;border-radius:8px;color:#922b21;font-weight:700;font-size:16px;\">\n      ⚠️ HIGH TRAFFIC\n    </div>\n  </div>\n</div>\n</div>",
